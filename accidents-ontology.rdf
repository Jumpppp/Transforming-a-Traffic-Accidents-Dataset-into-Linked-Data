    <!-- http://www.semanticweb.org/jump/ontologies/2026/2/untitled-ontology-22/Accident -->

    <owl:Class rdf:about="http://www.semanticweb.org/jump/ontologies/2026/2/untitled-ontology-22/Accident">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/jump/ontologies/2026/2/untitled-ontology-22/hasVehicle"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/jump/ontologies/2026/2/untitled-ontology-22/Vehicle"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/jump/ontologies/2026/2/untitled-ontology-22/hasWeatherCondition"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/jump/ontologies/2026/2/untitled-ontology-22/WeatherCondition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/jump/ontologies/2026/2/untitled-ontology-22/occursAtTime"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/jump/ontologies/2026/2/untitled-ontology-22/TimeInstant"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/jump/ontologies/2026/2/untitled-ontology-22/Event"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/jump/ontologies/2026/2/untitled-ontology-22/hasSeverity"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/jump/ontologies/2026/2/untitled-ontology-22/InjurySeverity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


