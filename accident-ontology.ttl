#################################################################
#    Classes
#################################################################

###  https://example.org/traffic-accident-ontology#Accident
:Accident rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty owl:topObjectProperty ;
                            owl:someValuesFrom :Event
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasVehicle ;
                            owl:someValuesFrom :Vehicle
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasWeatherCondition ;
                            owl:someValuesFrom :WeatherCondition
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :occursAtTime ;
                            owl:someValuesFrom :TimeInstant
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasSeverity ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :InjurySeverity
                          ] .


