           :hasWeatherCondition :Clear ;
           :accidentDateTime "2023-07-29T13:00:00Z"^^xsd:dateTime ;
           :numberOfDeaths 0 ;
           :numberOfInjured 0 ;
           :numberOfVehicles 2 .


