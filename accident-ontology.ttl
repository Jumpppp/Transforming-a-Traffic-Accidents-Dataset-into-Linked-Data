#    Object Properties
#################################################################

###  https://example.org/traffic-accident-ontology#hasCause
:hasCause rdf:type owl:ObjectProperty ;
          rdfs:domain [ rdf:type owl:Restriction ;
                        owl:onProperty :hasTrafficControlDevice ;
                        owl:someValuesFrom :Accident
                      ] ;
          rdfs:range [ rdf:type owl:Restriction ;
                       owl:onProperty :hasCause ;
                       owl:someValuesFrom :Cause
                     ] .


